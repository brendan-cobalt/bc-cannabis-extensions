{
  "payload": {
    "export": "cart-validations-generate-run",
    "target": "cart.validations.generate.run",
    "input": {
      "cart": {
        "cost": { "subtotalAmount": { "amount": "100.00" } },
        "buyerIdentity": { "purchasingCompany": null },
        "lines": [
          {
            "id": "gid://shopify/CartLine/1",
            "quantity": 6,
            "b2bOrderLimit": { "value": "100" },
            "gramEquivalency": null,
            "merchandise": {
              "__typename": "ProductVariant",
              "id": "gid://shopify/ProductVariant/1000000000001",
              "sku": "META-WINS",
              "b2bOrderLimitMetafield": { "value": "5" },
              "gramEquivalencyMetafield": null
            }
          }
        ]
      }
    },
    "output": {
      "operations": [
        {
          "validationAdd": {
            "errors": [
              {
                "message": "Order limit exceeded (SKU META-WINS): this product is limited to 5 per order. Please reduce the quantity to continue.",
                "target": "$.cart.lines[0].quantity"
              }
            ]
          }
        }
      ]
    }
  }
}
